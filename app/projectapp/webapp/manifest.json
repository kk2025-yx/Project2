{
  "_version": "1.85.0",
  "sap.app": {
    "id": "com.ai.adapter.projectapp",
    "type": "application",
    "title": "Project App",
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/project2/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui5": {
    "dependencies": {
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "settings": {
          "operationMode": "Server"
        }
      }
    },
    "routing": {
      "routes": [
        {
          "pattern": ":?query:",
          "name": "IntegrationTasksList",
          "target": "IntegrationTasksList"
        }
      ],
      "targets": {
        "IntegrationTasksList": {
          "type": "Component",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Tasks"
            },
            "extensions": {
              "sap.ui.controllerExtensions": {
                "sap.fe.templates.ListReport.view.ListReport": {
                  "controllerName": "com.ai.adapter.projectapp.ext.controller.ListReportExtension"
                }
              }
            }
          }
        }
      }
    }
  }
}